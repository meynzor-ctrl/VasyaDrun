local function CreateBulletTracer(targetPos)
    if not getgenv().VasyaV16.Visuals.BulletTracers then return end
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    
    task.spawn(function()
        local startPos = char.HumanoidRootPart.Position
        local beam = Instance.new("Part")
        beam.Parent = workspace
        beam.Anchored = true
        beam.CanCollide = false
        beam.Material = Enum.Material.Neon
        beam.Color = Color3.fromRGB(0, 255, 150)
        beam.Transparency = 0.3
        
        local dist = (startPos - targetPos).Magnitude
        beam.Size = Vector3.new(0.1, 0.1, dist)
        beam.CFrame = CFrame.new(startPos:Lerp(targetPos, 0.5), targetPos)
        
        local tween = TWS:Create(beam, TweenInfo.new(0.5), {Transparency = 1, Size = Vector3.new(0,0,dist)})
        tween:Play()
        tween.Completed:Connect(function() beam:Destroy() end)
    end)
end

