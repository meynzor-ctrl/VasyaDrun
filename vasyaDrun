-- [3] ТЕХНОЛОГИЯ SILENT AIM (REDIRECTION V2)
-- ==========================================================
local function IsVisible(part)
    if not getgenv().VasyaV16.Combat.VisibleCheck then return true end
    local castPoints = {part.Position}
    local ignoreList = {LocalPlayer.Character, Camera}
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = ignoreList
    
    local result = workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * 1000, params)
    return result and result.Instance:IsDescendantOf(part.Parent)
end

local function GetBestTarget()
    local target = nil
    local maxDist = getgenv().VasyaV16.Combat.FOV
    local mousePos = UIS:GetMouseLocation()

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Humanoid") then
            local humanoid = plr.Character.Humanoid
            local part = plr.Character:FindFirstChild(getgenv().VasyaV16.Combat.HitPart)
            
            if humanoid.Health > 0 and part then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                
                if onScreen then
                    local mag = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if mag < maxDist then
                        if IsVisible(part) then
                            maxDist = mag
                            target = part
                        end
                    end
                end
            end
        end
    end
    return target
end

-- Основной хук для Сайлента
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    if getgenv().VasyaV16.Combat.SilentAim and CurrentTarget then
        -- Перехватываем Raycast, FindPartOnRay и даже FireServer (в некоторых играх)
        if method == "Raycast" and not checkcaller() then
            args[2] = (CurrentTarget.Position - args[1]).Unit * 1000
            return oldNamecall(self, unpack(args))
        elseif (method == "FindPartOnRay" or method == "FindPartOnRayWithIgnoreList") and not checkcaller() then
            args[1] = Ray.new(args[1].Origin, (CurrentTarget.Position - args[1].Origin).Unit * 1000)
            return oldNamecall(self, unpack(args))
        end
    end

    return oldNamecall(self, ...)
end))

-- Дополнительный хук для игр на FastCast / Mouse.Hit
